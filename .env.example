# AINative Studio Live - Environment Configuration
# Copy this file to .env.local and fill in your values

# ==================== API Configuration ====================

# Production API Base URL (default)
NEXT_PUBLIC_API_URL=https://api.ainative.studio/v1

# Production WebSocket URL (default)
NEXT_PUBLIC_WS_URL=wss://api.ainative.studio/v1

# Development API Base URL (optional - uncomment for local development)
# NEXT_PUBLIC_API_URL_DEV=http://localhost:8000/v1

# Development WebSocket URL (optional - uncomment for local development)
# NEXT_PUBLIC_WS_URL_DEV=ws://localhost:8000/v1

# ==================== Feature Flags ====================

# Enable live chat functionality
NEXT_PUBLIC_ENABLE_CHAT=true

# Enable VOD (Video on Demand) functionality
NEXT_PUBLIC_ENABLE_VOD=true

# ==================== Optional Configuration ====================

# Analytics tracking ID (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=

# Environment identifier (development, staging, production)
# NEXT_PUBLIC_ENV=production
